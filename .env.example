ADMIN_DEFAULT_PASSWORD=changeme123
JWT_SECRET=replace-this-in-production

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=egoflow

# Connection URLs (DATABASE_URL is composed from POSTGRES_* vars in compose.yml)
REDIS_URL=redis://redis:6379
# HF_TOKEN=

# Optional public URL overrides for non-local deployments
# PUBLIC_RTMP_BASE_URL=rtmp://your-host:1935/live
# PUBLIC_HLS_BASE_URL=http://your-host/hls
# RTMPS_ENCRYPTION_MODE=no
# RTMPS_CERT_PATH=/certs/server.crt
# RTMPS_KEY_PATH=/certs/server.key

# Optional internal override for MediaMTX API access
# MEDIAMTX_API_URL=http://mediamtx:9997
